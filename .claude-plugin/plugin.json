{
  "name": "harness",
  "version": "1.1.0",
  "description": "Adviser Group Claude Code harness — pipeline orchestration, specialized agents, and engineering-discipline hooks.",
  "author": { "name": "Adviser Group Platform Engineering", "email": "platform-eng@aberdeenplc.com" },
  "homepage": "https://github.com/Adviser-Group/.claude",
  "keywords": ["pipeline", "orchestration", "tdd", "adviser-group"],
  "hooks": "./hooks/hooks.json",
  "mcpServers": {
    "gh-cache": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/_lib/github-cache-server.py"]
    },
    "memory": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/skills/mcp_memory/server.py"]
    },
    "lsp-typescript": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/_lib/lsp-bridge-server.py", "--language", "ts"]
    },
    "lsp-pyright": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/_lib/lsp-bridge-server.py", "--language", "py"]
    }
  }
}
