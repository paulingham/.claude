{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_HOOK_PROFILE": "standard",
    "CLAUDE_PIPELINE_TASK_ID": "",
    "HCOM": "/Users/Paul.Ingham/.local/bin/hcom",
    "HF_TOKEN_PATH": "/Users/Paul.Ingham/.config/parry-guard/hf_token",
    "HF_TOKEN": "REDACTED",
    "ORT_DYLIB_PATH": "/opt/homebrew/lib/libonnxruntime.dylib"
  },
  "permissions": {
    "allow": [
      "Bash(/Users/Paul.Ingham/.local/bin/hcom send:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom start:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom help:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom --help)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom -h)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom list:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom events:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom listen:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom relay:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom config:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom transcript:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom archive:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom bundle:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom status:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom term:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom hooks:*)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom --version)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom -v)",
      "Bash(/Users/Paul.Ingham/.local/bin/hcom --new-terminal)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)"
    ],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} notify"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"decision\":{\"behavior\":\"allow\"}}}'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} permission-request"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ls pipeline-state/*-pipeline.md 2>/dev/null && echo 'Pipeline state files found — resume from current phase.' || echo 'No active pipeline.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/context-warning.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/observation-capture.sh"
          },
          {
            "type": "command",
            "command": "~/.cargo/bin/parry-guard hook"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/code-shape-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/function-body-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cc-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/injection-scan.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/code-shape-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/function-body-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cc-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/injection-scan.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-bug-detect.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} post",
            "timeout": 86400
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PRE-COMPACTION: Verify pipeline state is saved in pipeline-state/*-pipeline.md before context compression.'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/quality-gate.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sast-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/commit-checkpoint.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh"
          },
          {
            "type": "command",
            "command": "dippy check"
          },
          {
            "type": "command",
            "command": "~/.cargo/bin/parry-guard hook"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tdd-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/orchestrator-discipline.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-protection.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tdd-guard.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/orchestrator-discipline.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-protection.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/agent-skill-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Task|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} pre"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session ending. Active worktrees:' && git worktree list 2>/dev/null | grep -v 'bare' || echo 'None'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} sessionend"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start-bootstrap.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'CONTEXT COMPACTED — Critical reminders:\\n1. Check pipeline-state/*-pipeline.md for in-progress pipelines before continuing any work\\n2. Rules are in ~/.claude/rules/ — review if uncertain about protocol\\n3. All code changes go through agents (orchestrator never writes source files)\\n4. Skills are mandatory for pipeline phases — invoke via Skill tool\\n5. Agent Teams enabled — use for complex multi-domain work\\n6. Specialized agents (code-reviewer, software-engineer) have persistent memory — check .claude/agent-memory/'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} sessionstart"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-pr.sh",
            "timeout": 15
          },
          {
            "type": "agent",
            "prompt": "Verify the current task is truly complete before stopping. Check: 1) Run the test suite if there are code changes and confirm all tests pass, 2) Run git status to check for uncommitted changes, 3) Look for TODO or FIXME comments in recently changed files (git diff --name-only | xargs grep -l 'TODO\\|FIXME' 2>/dev/null), 4) If a pipeline is in progress, verify pipeline-state/*-pipeline.md is up to date with current phase status. If anything is incomplete, respond with {\"ok\": false, \"reason\": \"what remains\"}. If this was just a question/conversation (no code changes), respond with {\"ok\": true}. IMPORTANT: Check the stop_hook_active field in your input - if true, respond with {\"ok\": true} immediately to avoid infinite loops.",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cost-tracker.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} poll",
            "timeout": 86400
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'SESSION STOPPED DUE TO ERROR. If a pipeline is in progress, state should be in pipeline-state/*-pipeline.md. Resume in a new session.' >&2"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} subagent-start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-validation.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-stop-trajectory.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} subagent-stop",
            "timeout": 86400
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/intake-reminder.sh"
          },
          {
            "type": "command",
            "command": "~/.cargo/bin/parry-guard hook"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} userpromptsubmit"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-robbyrussell.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "supply-chain-risk-auditor@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "differential-review@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "static-analysis@trailofbits": true
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto"
}
