{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_HOOK_PROFILE": "standard",
    "CLAUDE_PIPELINE_TASK_ID": "",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "CLAUDE_PIPELINE_MODE": "autonomous",
    "CLAUDE_ENABLE_TRACE": "1",
    "CLAUDE_SUBAGENT_MAX_DEPTH": "3",
    "CLAUDE_SUBAGENT_MAX_RUNTIME": "1800",
    "CLAUDE_TEAMMATE_MAX_RUNTIME": "3600"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash",
      "Agent",
      "Skill",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "SendMessage",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "TeamCreate",
      "TeamDelete",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "Write($HOME/.claude/**)",
      "Edit($HOME/.claude/**)",
      "Read($HOME/.claude/**)",
      "Bash(rm $HOME/.claude/**)",
      "Bash(rm -f $HOME/.claude/**)",
      "Bash(rm -rf $HOME/.claude/pipeline-state/**)",
      "Bash(rm -rf $HOME/.claude/session-memory/**)",
      "Bash(rm -rf $HOME/.claude/agent-memory/**)",
      "Bash(rm -rf $HOME/.claude/learning/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /Users*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /tmp*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(> /dev/sda*)",
      "Bash(chmod -R 777 /*)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "$HOME/.claude/pipeline-state",
      "$HOME/.claude/session-memory",
      "$HOME/.claude/agent-memory",
      "$HOME/.claude/learning",
      "$HOME/.claude/automation",
      "$HOME/.claude/skills",
      "$HOME/.claude/tests",
      "$HOME/.claude/hooks",
      "$HOME/.claude/agents",
      "$HOME/.claude/rules",
      "$HOME/.claude/scripts",
      "$HOME/.claude/db",
      "$HOME/.claude/manifests"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom notify",
            "timeout": 10000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom permission-request",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{ ls pipeline-state/*-pipeline.md pipeline-state/*/pipeline.md; } 2>/dev/null && echo 'Pipeline state files found — resume from current phase.' || echo 'No active pipeline.'",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/context-warning.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/observation-capture.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tool-timing-capture.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/code-shape-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/function-body-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cc-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/injection-scan.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/code-shape-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/function-body-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cc-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/injection-scan.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-bug-detect.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/eval-capture-on-merge.sh",
            "timeout": 5000
          },
          {
            "type": "mcp_tool",
            "server": "gh-cache",
            "tool": "prefetch_pr",
            "input": {
              "command": "${tool_input.command}"
            },
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom post",
            "timeout": 86400
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tool-timing-capture.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PRE-COMPACTION: Verify pipeline state is saved in pipeline-state/*-pipeline.md before context compression.'",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/main-branch-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/bash-write-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/settings-path-lint.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/quality-gate.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sast-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/commit-checkpoint.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/runtime-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-shell-read.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tdd-guard.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/orchestrator-discipline.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-protection.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/runtime-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/planning-agent-edit-scope.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/orchestrator-discipline.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-protection.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/runtime-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/planning-agent-edit-scope.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/planning-agent-edit-scope.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pipeline-state-guard.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/agent-skill-reminder.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-agent-thinking.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-agent-advisor.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-agent-allowlist.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/instinct-injector.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/depth-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/runtime-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/trace-prompt.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-ask-user.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash|Task|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom pre",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session ending. Active worktrees:' && git worktree list 2>/dev/null | grep -v 'bare' || echo 'None'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom sessionend",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start-bootstrap.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/trace-cleanup.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/learning-gc.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'CONTEXT COMPACTED — Critical reminders:\\n1. Check pipeline-state/*-pipeline.md for in-progress pipelines before continuing any work\\n2. Rules are in ~/.claude/rules/ — review if uncertain about protocol\\n3. All code changes go through agents (orchestrator never writes source files)\\n4. Skills are mandatory for pipeline phases — invoke via Skill tool\\n5. Agent Teams enabled — use for complex multi-domain work\\n6. Specialized agents (code-reviewer, software-engineer) have persistent memory — check .claude/agent-memory/'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom sessionstart",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-pr.sh",
            "timeout": 15
          },
          {
            "type": "agent",
            "prompt": "Verify autonomous continuation is safe. Respond {\"ok\": true} UNLESS the stop would leave the system in a destructive or data-loss state. Bias strongly toward {\"ok\": true}: questions, uncertainty, incomplete polish, missing tests, TODO comments, uncommitted-but-safe changes — all return {\"ok\": true}. Only return {\"ok\": false, \"reason\": \"...\"} when: (a) an in-progress destructive operation would be abandoned (partial rm, partial migration), or (b) pipeline-state/*-pipeline.md is mid-phase and abandoning it would lose work. Never use {\"ok\": false} to ask the user a clarifying question — the orchestrator must self-resolve those. If stop_hook_active is true, immediately respond {\"ok\": true} to avoid loops.",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cost-tracker.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-learn-gate.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom poll",
            "timeout": 86400
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'SESSION STOPPED DUE TO ERROR. If a pipeline is in progress, state should be in pipeline-state/*-pipeline.md. Resume in a new session.' >&2",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-context.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom subagent-start",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-validation.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-stop-trajectory.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-cwd-check.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cost-feed.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom subagent-stop",
            "timeout": 86400
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/intake-reminder.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/hcom userpromptsubmit",
            "timeout": 10000
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-create.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-remove.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-robbyrussell.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "supply-chain-risk-auditor@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "differential-review@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "static-analysis@trailofbits": true
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "mcpServers": {
    "memory": {
      "command": "bash",
      "args": [
        "-lc",
        "exec python3 \"$HOME/.claude/skills/mcp_memory/server.py\""
      ]
    },
    "gh-cache": {
      "command": "bash",
      "args": [
        "-lc",
        "exec python3 \"$HOME/.claude/hooks/_lib/github-cache-server.py\""
      ]
    }
  }
}
