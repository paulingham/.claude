{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_HOOK_PROFILE": "standard",
    "CLAUDE_PIPELINE_TASK_ID": "",
    "HCOM": "/Users/Paul.Ingham/.local/bin/hcom",
    "HF_TOKEN_PATH": "/Users/Paul.Ingham/.config/parry-guard/hf_token",
    "HF_TOKEN": "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",
    "ORT_DYLIB_PATH": "/opt/homebrew/lib/libonnxruntime.dylib",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash",
      "Agent",
      "Skill",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "SendMessage",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "TeamCreate",
      "TeamDelete",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /Users*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /tmp*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(> /dev/sda*)",
      "Bash(chmod -R 777 /*)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)"
    ],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} notify",
            "timeout": 10000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} permission-request",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ls pipeline-state/*-pipeline.md 2>/dev/null && echo 'Pipeline state files found \u2014 resume from current phase.' || echo 'No active pipeline.'",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/context-warning.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/observation-capture.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "~/.cargo/bin/parry-guard hook",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/code-shape-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/function-body-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cc-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/injection-scan.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/code-shape-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/function-body-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cc-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/injection-scan.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-bug-detect.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} post",
            "timeout": 86400
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PRE-COMPACTION: Verify pipeline state is saved in pipeline-state/*-pipeline.md before context compression.'",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/quality-gate.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sast-check.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/commit-checkpoint.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "dippy check",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "~/.cargo/bin/parry-guard hook",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tdd-guard.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/orchestrator-discipline.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-protection.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tdd-guard.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/orchestrator-discipline.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-protection.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/governance-capture.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pipeline-state-guard.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/agent-skill-reminder.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash|Task|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} pre",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session ending. Active worktrees:' && git worktree list 2>/dev/null | grep -v 'bare' || echo 'None'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} sessionend",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start-bootstrap.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "printf 'CONTEXT COMPACTED \u2014 Critical reminders:\\n1. Check pipeline-state/*-pipeline.md for in-progress pipelines before continuing any work\\n2. Rules are in ~/.claude/rules/ \u2014 review if uncertain about protocol\\n3. All code changes go through agents (orchestrator never writes source files)\\n4. Skills are mandatory for pipeline phases \u2014 invoke via Skill tool\\n5. Agent Teams enabled \u2014 use for complex multi-domain work\\n6. Specialized agents (code-reviewer, software-engineer) have persistent memory \u2014 check .claude/agent-memory/'",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} sessionstart",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-pr.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-reduce-permissions.sh",
            "timeout": 10
          },
          {
            "type": "agent",
            "prompt": "Verify the current task is truly complete before stopping. Check: 1) Run the test suite if there are code changes and confirm all tests pass, 2) Run git status to check for uncommitted changes, 3) Look for TODO or FIXME comments in recently changed files (git diff --name-only | xargs grep -l 'TODO\\|FIXME' 2>/dev/null), 4) If a pipeline is in progress, verify pipeline-state/*-pipeline.md is up to date with current phase status. If anything is incomplete, respond with {\"ok\": false, \"reason\": \"what remains\"}. If this was just a question/conversation (no code changes), respond with {\"ok\": true}. IMPORTANT: Check the stop_hook_active field in your input - if true, respond with {\"ok\": true} immediately to avoid infinite loops.",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cost-tracker.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} poll",
            "timeout": 86400
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'SESSION STOPPED DUE TO ERROR. If a pipeline is in progress, state should be in pipeline-state/*-pipeline.md. Resume in a new session.' >&2",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-context.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "${HCOM} subagent-start",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-validation.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/subagent-stop-trajectory.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} subagent-stop",
            "timeout": 86400
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/intake-reminder.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "~/.cargo/bin/parry-guard hook",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${HCOM} userpromptsubmit",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-robbyrussell.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "supply-chain-risk-auditor@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "differential-review@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "static-analysis@trailofbits": true
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto"
}
