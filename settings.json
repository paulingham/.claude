{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_HOOK_PROFILE": "standard",
    "ENABLE_TOOL_SEARCH": "true",
    "_doc_ENABLE_TOOL_SEARCH": "Pin explicit. Default already defers all MCP tools behind ToolSearch (lowest upfront-token cost). `auto` was REJECTED at intake because its 10%-context-window threshold mode loads small servers upfront — INCREASES tool-definition tokens vs default. This pin guards against a future Claude Code default flip. Source: https://code.claude.com/docs/en/mcp#scale-with-mcp-tool-search. Requires Sonnet 4+ or Opus 4+ (Haiku unsupported). See protocols/_proposals/2026-05-15-mcp-tool-config.md for full rationale.",
    "CLAUDE_PIPELINE_TASK_ID": "",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_PIPELINE_MODE": "autonomous",
    "CLAUDE_ENABLE_TRACE": "0",
    "CLAUDE_SUBAGENT_MAX_DEPTH": "3",
    "CLAUDE_SUBAGENT_MAX_RUNTIME": "1800",
    "CLAUDE_TEAMMATE_MAX_RUNTIME": "3600"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash",
      "Agent",
      "Skill",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "SendMessage",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "TeamCreate",
      "TeamDelete",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "Write($HOME/.claude/**)",
      "Edit($HOME/.claude/**)",
      "Read($HOME/.claude/**)",
      "Bash(rm $HOME/.claude/**)",
      "Bash(rm -f $HOME/.claude/**)",
      "Bash(rm -rf $HOME/.claude/pipeline-state/**)",
      "Bash(rm -rf $HOME/.claude/session-memory/**)",
      "Bash(rm -rf $HOME/.claude/agent-memory/**)",
      "Bash(rm -rf $HOME/.claude/learning/**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /Users*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /tmp*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(> /dev/sda*)",
      "Bash(chmod -R 777 /*)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D main)",
      "Bash(git branch -D master)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "$HOME/.claude/pipeline-state",
      "$HOME/.claude/session-memory",
      "$HOME/.claude/agent-memory",
      "$HOME/.claude/learning",
      "$HOME/.claude/automation",
      "$HOME/.claude/skills",
      "$HOME/.claude/tests",
      "$HOME/.claude/hooks",
      "$HOME/.claude/agents",
      "$HOME/.claude/rules",
      "$HOME/.claude/scripts",
      "$HOME/.claude/db",
      "$HOME/.claude/manifests",
      "$HOME/.claude/.claude/worktrees"
    ]
  },
