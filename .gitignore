# Everything ignored by default
*

# Reusable config — explicitly tracked
!.gitignore
!README.md
!CLAUDE.md
!settings.json
!rules/
!rules/**
!protocols/
!protocols/**
!skills/
!skills/**
!hooks/
!hooks/**
!hooks/tests/
!hooks/tests/**
!agents/
!agents/**
!orchestrator/
!orchestrator/**
!knowledge/
!knowledge/**
!pipeline-state/
!pipeline-state/**
!setup.sh
!statusline-command.sh
!statusline-robbyrussell.sh
!version-pin
!pyproject.toml
!agent-memory/
!agent-memory/**
!memory/
!memory/**
!automation/
!automation/**
!db/
!db/**
!tests/
!tests/**
!scripts/
!scripts/**
!eval/
!eval/**
!.github/
!.github/**
!session-memory/
!session-memory/**
!codebase_map/
!codebase_map/**

# Global seed instincts — tracked so they ship with the harness.
# Per-project accumulated instincts under learning/{project-hash}/ stay ignored
# (those are local observation-derived state, not source).
!learning/
!learning/instincts/
!learning/instincts/**

# Internal eval harness — runtime + candidate cases are local-only.
# Ignore directory contents but persist the directories themselves via tracked .gitkeep.
# Pattern uses `dir/*` (not `dir/`) so git descends and honours the .gitkeep negation.
eval/cases/.candidates/*
!eval/cases/.candidates/.gitkeep
eval/runs/*
!eval/runs/.gitkeep

# Python bytecode cache — never tracked
**/__pycache__/
*.pyc

# Runtime artifacts — never tracked
automation/logs/
automation/.permission-reducer-last-run
db/*.log
db/*.log.*
db/*.sqlite
db/*.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm

# Worktree-scoped scratch tools — see skills/tool-synthesis/. Per-worktree only;
# never merged. The skill also adds this entry to target repos' .gitignore.
.claude-scratch-tools/

# Never track secrets or credentials
credentials.json
.claude.json
.claude.json.backup
