# Everything ignored by default
*

# Reusable config — explicitly tracked
!.gitignore
!README.md
!ROLLOUT.md
!CLAUDE.md
!settings.json
!rules/
!rules/**
!protocols/
!protocols/**
!skills/
!skills/**
!hooks/
!hooks/**
!hooks/tests/
!hooks/tests/**
!agents/
!agents/**
!orchestrator/
!orchestrator/**
!knowledge/
!knowledge/**
# pipeline-state: only README is seed; runtime task dirs live in $HARNESS_DATA
!pipeline-state/README.md
!setup.sh
!managed-settings.json
!PORTING-NOTES.md
!statusline-command.sh
!statusline-robbyrussell.sh
!version-pin
!pyproject.toml
# agent-memory: role dirs, seed MEMORY.md, and role-level feedback_*.md tracked; per-session hash dirs are runtime state
!agent-memory/
!agent-memory/*/
!agent-memory/*/MEMORY.md
!agent-memory/*/feedback_*.md
!memory/
!memory/**
!automation/
!automation/**
# db: only schema.sql seed tracked; runtime *.sqlite and logs excluded via lower patterns
!db/
!db/schema.sql
!tests/
!tests/**
!scripts/
!scripts/**
!eval/
!eval/**
!.github/
!.github/**
# session-memory: config and adapters are seed; per-project hash dirs are runtime state
!session-memory/
!session-memory/config/
!session-memory/config/**
!session-memory/adapters/
!session-memory/adapters/**
# metrics: runtime JSONL logs ignored; curated cost/cache reports tracked
!metrics/
!metrics/reports/
!metrics/reports/**
# codebase_map: source code tracked (it is a Python package, not runtime state)
!codebase_map/
!codebase_map/**

# Global seed instincts — tracked so they ship with the harness.
# Per-project accumulated instincts under learning/{project-hash}/ stay ignored
# (those are local observation-derived state, not source).
!learning/
!learning/instincts/
!learning/instincts/**

# Internal eval harness — runtime + candidate cases are local-only.
# Ignore directory contents but persist the directories themselves via tracked .gitkeep.
# Pattern uses `dir/*` (not `dir/`) so git descends and honours the .gitkeep negation.
eval/cases/.candidates/*
!eval/cases/.candidates/.gitkeep
eval/runs/*
!eval/runs/.gitkeep

# Python bytecode cache — never tracked
**/__pycache__/
*.pyc

# Runtime artifacts — never tracked
automation/logs/
automation/.permission-reducer-last-run
db/*.log
db/*.log.*
db/*.sqlite
db/*.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm

# Plugin manifests — tracked so the harness ships as an installable plugin.
!.claude-plugin/
!.claude-plugin/**

# Worktree-scoped scratch tools — see skills/tool-synthesis/. Per-worktree only;
# never merged. The skill also adds this entry to target repos' .gitignore.
.claude-scratch-tools/

# Fixture deps dirs — runtime npm install; never tracked
tests/fixtures/accessibility-check/.deps/

# Never track secrets or credentials
credentials.json
.claude.json
.claude.json.backup
