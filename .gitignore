!pipeline-state/**
!setup.sh
!statusline-command.sh
!statusline-robbyrussell.sh
!agent-memory/
!agent-memory/**
!memory/
!memory/**
!automation/
!automation/**
!db/
!db/**
!tests/
!tests/**
!scripts/
!scripts/**

# Python bytecode cache — never tracked
**/__pycache__/
*.pyc

# Never track secrets or credentials
credentials.json
.claude.json
.claude.json.backup
