{
  "permissions": {
    "allow": [
      "Bash(npm run test)",
      "Write($HOME/.claude/**)",
      "Edit($HOME/.claude/**)",
      "Read($HOME/.claude/**)",
      "Bash(mkdir *)",
      "Bash(mkdir -p *)",
      "Bash(touch *)",
      "Bash(git *)",
      "Bash(rm $HOME/.claude/**)",
      "Bash(rm -f $HOME/.claude/**)",
      "Bash(rm -rf $HOME/.claude/pipeline-state/**)",
      "Bash(rm -rf $HOME/.claude/session-memory/**)",
      "Bash(rm -rf $HOME/.claude/agent-memory/**)",
      "Bash(rm -rf $HOME/.claude/learning/**)"
    ],
    "defaultMode": "bypassPermissions"
  }
}
